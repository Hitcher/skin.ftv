<?xml version="1.0" encoding="UTF-8"?>
<window>
	<!-- startup -->
	<backgroundcolor>BackgroundColour</backgroundcolor>
	<defaultcontrol always="true">99</defaultcontrol>
	<onload>SetProperty(StartUp,true,home)</onload>
	<controls>
		<control type="button" id="99">
			<include>HiddenControl</include>
			<onfocus condition="Skin.HasSetting(firstrun)">ReplaceWindow($INFO[System.StartupWindow])</onfocus>
			<onfocus condition="!Skin.HasSetting(firstrun)">SetFocus(100)</onfocus>
		</control>
		<control type="button" id="100">
			<include>HiddenControl</include>
			<onfocus>Skin.SetBool(ExtendedInfo)</onfocus>
			<onfocus>Skin.SetBool(EnableFanart)</onfocus>
			<onfocus>Skin.SetBool(EnableXRay)</onfocus>
			<onfocus>Skin.SetBool(TomatoMeterAllCritics)</onfocus>
			<onfocus>Skin.SetBool(US)</onfocus>
			<onfocus>ReplaceWindow($INFO[System.StartupWindow])</onfocus>
			<onfocus>Skin.SetBool(firstrun)</onfocus>
		</control>
	</controls>
</window>
