				<property name="ArtFanart1">$INFO[Container($MATH[$PROPERTY[groupId] + $PROPERTY[index]]).ListItemPosition(0).Art(fanart)]</property>
				<property name="ArtFanart2">$INFO[Container($MATH[$PROPERTY[groupId] + $PROPERTY[index]]).ListItemPosition(1).Art(fanart)]</property>
