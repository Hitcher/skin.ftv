				<property name="ArtLogo2">$INFO[Container($MATH[$PROPERTY[groupId] + $PROPERTY[index]]).ListItemPosition(1).Art(clearlogo)]</property>
				<property name="ArtLogo3">$INFO[Container($MATH[$PROPERTY[groupId] + $PROPERTY[index]]).ListItemPosition(2).Art(clearlogo)]</property>
				<onclick>ActivateWindow($PROPERTY[widgetTarget],&quot;$PROPERTY[widgetPath]&quot;,return)</onclick>
			</item>
		</controls>
	</template>
</templates>
