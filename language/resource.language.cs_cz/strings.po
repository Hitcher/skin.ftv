msgctxt "Addon Summary"
msgid "Skin based on the original Fire TV UI"
msgstr "Vzhled založený na původním rozhraní Fire TV"

msgctxt "Addon Description"
msgid "A skin designed to access all your content as easily and seemlessly as possible.[CR][CR]Addons supported:[CR]Global Search[CR]Up Next[CR]TheMovieDb Helper[CR]Trakt[CR]CU Lyrics[CR]Cinema Experience[CR]Special Features[CR][CR]Based on the original Fire TV UI."
msgstr "Vzhled navržený tak, aby byl přístup k veškerému vašemu obsahu co nejjednodušší a nejplynulejší.[CR][CR]Podporované doplňky:[CR]Global Search[CR]Up Next[CR]TheMovieDb Helper[CR]Trakt[CR]CU Lyrics[CR]Cinema Experience[CR]Special Features[CR][CR]Založeno na původním rozhraní Fire TV."

msgctxt "Addon Disclaimer"
